  "keyFeatures": [
    "JIT compilation via LLVM backend",
    "Custom bytecode virtual machine (YVM) backend",
    "Memory safety via borrow checker with domain analysis",
    "Statically typed with generics and type inference",
    "Embeddable in C++20 applications via AppModule API",
    "Fiber/coroutine-based concurrency model",
    "Operator overloading",
    "Interface/trait system",
    "GC references alongside borrow-checked references",
    "String interpolation with `${}` syntax"
  ],
